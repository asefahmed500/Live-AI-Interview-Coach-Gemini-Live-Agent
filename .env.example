# Application
NODE_ENV=development

# API Configuration
API_PORT=3001
API_HOST=0.0.0.0
API_PREFIX=api
API_URL=http://localhost:3001

# Web Configuration
WEB_PORT=3000
WEB_URL=http://localhost:3000

# WebSocket
WS_PORT=3001
WS_URL=ws://localhost:3001

# MongoDB
MONGODB_URI=mongodb://localhost:27017/live-interview-coach

# CORS (Comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Authentication
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRATION=7d

# Rate Limiting / Throttling
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Logging
LOG_LEVEL=info

# Gemini API (Live API)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_ENABLE_LOGGING=true
GEMINI_ENABLE_METRICS=true
GEMINI_TIMEOUT=120000

# Google Cloud (Optional - for Vertex AI)
# If not set, uses Google AI Developer API
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# USE_VERTEX_AI=false

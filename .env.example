# Application
NODE_ENV=development

# API Configuration
API_PORT=3001
API_HOST=0.0.0.0
API_PREFIX=api
API_URL=http://localhost:3001

# Web Configuration
WEB_PORT=3000
WEB_URL=http://localhost:3000

# WebSocket
WS_PORT=3001
WS_URL=ws://localhost:3001

# MongoDB
MONGODB_URI=mongodb://localhost:27017/live-interview-coach

# CORS (Comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Authentication (Legacy JWT - being migrated to Better Auth)
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRATION=7d

# Better Auth Configuration
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3001

# Rate Limiting / Throttling
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Logging
LOG_LEVEL=info

# Gemini API (Live API)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_ENABLE_LOGGING=true
GEMINI_ENABLE_METRICS=true
GEMINI_TIMEOUT=120000

# Google Cloud (Optional - for Vertex AI)
# If not set, uses Google AI Developer API
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# USE_VERTEX_AI=false

# Production URLs (for frontend deployment)
# These should be set in Vercel environment variables
# NEXT_PUBLIC_API_URL=https://live-interview-api-ywh3e45esq-uc.a.run.app
# NEXT_PUBLIC_WS_URL=wss://live-interview-api-ywh3e45esq-uc.a.run.app

# Google Cloud Deployment
# GOOGLE_CLOUD_PROJECT=voice-ai-agent-447515
# GOOGLE_CLOUD_REGION=us-central1
